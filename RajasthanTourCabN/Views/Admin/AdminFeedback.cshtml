@model IEnumerable<RajasthanTourCabN.Models.Feedback>
@{
    ViewBag.Title = "Feedback List";

    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container mt-4">

    <h2 class="mb-4">Feedback List</h2>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Rating</th>
                <th>Comments</th>
                <th>Submitted On</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Rating</td>
                    <td>@item.Comments</td>
                    <td>@item.SubmittedOn.ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
</div>