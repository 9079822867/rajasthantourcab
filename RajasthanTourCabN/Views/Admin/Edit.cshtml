@model RajasthanTourCabN.Models.Page

<h2>Edit Page</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(x => x.Id)

    <div class="mb-2">
        <label>Title</label>
        @Html.TextBoxFor(x => x.Title, new { @class = "form-control", id = "Title" })
    </div>

    <div class="mb-2">
        <label>Slug</label>
        @Html.TextBoxFor(x => x.Slug, new { @class = "form-control", id = "Slug" })
    </div>

    <div class="mb-2">
        <label>Content</label>
        @Html.TextAreaFor(x => x.Content, new { @class = "form-control", id = "editor" })
    </div>

    <div class="mb-2">
        <label>Parent Menu</label>
        @Html.DropDownListFor(x => x.ParentId,
            new SelectList(ViewBag.Parents, "Id", "Title", Model.ParentId),
            "No Parent",
            new { @class = "form-control" })
    </div>

    <div class="mb-2">
        <label>Display Order</label>
        @Html.TextBoxFor(x => x.DisplayOrder, new { @class = "form-control" })
    </div>

    <!-- SEO -->
    <div class="mb-2">
        <label>Meta Title</label>
        @Html.TextBoxFor(x => x.MetaTitle, new { @class = "form-control" })
    </div>

    <div class="mb-2">
        <label>Meta Description</label>
        @Html.TextAreaFor(x => x.MetaDescription, new { @class = "form-control" })
    </div>

    <div class="mb-2">
        <label>Active</label>
        @Html.CheckBoxFor(x => x.IsActive)
    </div>

    <button type="submit" class="btn btn-success">Update Page</button>
}
