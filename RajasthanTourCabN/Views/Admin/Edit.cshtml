<!-- CKEditor Full Version -->
<script src="https://cdn.ckeditor.com/4.21.0/full/ckeditor.js"></script>
<script>
    // Initialize CKEditor
    CKEDITOR.replace('editor', {
        height: 400,
        allowedContent: true,
        extraAllowedContent: '*(*);*{*};*[*];',

        removeEmpty: false,
        fillEmptyBlocks: false,
        ignoreEmptyParagraph: true,
        protectedSource: [/<i[\s\S]*?<\/i>/g],
        //extraAllowedContent: '*(*);*{*};',
        // Enable full HTML (no restriction)
        //allowedContent: true,

        // Toolbar with Source button
        toolbar: [
            { name: 'document', items: ['Source'] },
            { name: 'clipboard', items: ['Undo', 'Redo'] },
            { name: 'styles', items: ['Format', 'Font', 'FontSize'] },
            { name: 'basicstyles', items: ['Bold', 'Italic', 'Underline'] },
            { name: 'paragraph', items: ['NumberedList', 'BulletedList', 'JustifyLeft', 'JustifyCenter', 'JustifyRight'] },
            { name: 'insert', items: ['Image', 'Table', 'Link'] },
            { name: 'tools', items: ['Maximize'] }
        ]
    });

    // Get HTML content
    function getData() {
        var data = CKEDITOR.instances.editor.getData();
        document.getElementById("output").innerHTML = data;

        console.log(data); // for debugging
    }
    document.querySelector("form").addEventListener("submit", function () {
        // Ensure we read the data from the active editor instance.
        var data = "";
        if (typeof CKEDITOR !== 'undefined' && CKEDITOR.instances && CKEDITOR.instances['editor']) {
            data = CKEDITOR.instances['editor'].getData();
        }
        else if (typeof editorInstance !== 'undefined' && editorInstance && typeof editorInstance.getData === 'function') {
            // fallback if a ClassicEditor (CKEditor5) instance is present
            data = editorInstance.getData();
        }

        var textarea = document.querySelector("#editor");
        if (textarea) textarea.value = data;
    });
</script>
<script>
    document.querySelector("#Title").addEventListener("keyup", function () {
        let slug = this.value.toLowerCase()
            .replace(/ /g, '-')
            .replace(/&/g, 'and')
            .replace(/--+/g, '-');

        document.querySelector("#Slug").value = slug;
    });
</script>