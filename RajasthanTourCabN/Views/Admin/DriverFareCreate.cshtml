@model RajasthanTourCabN.Models.DriverFare
@{
    ViewBag.Title = "Add Driver Fare";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Add Driver Fare</h2>

@using (Html.BeginForm())
{
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-2">
        <label>Category</label>
        @Html.DropDownListFor(x => x.Category,
            new SelectList(new[] { "Hourly", "Daily" }, Model.Category),
            new { @class = "form-control" })
    </div>

    <div class="mb-2">
        <label>Duration</label>
        @Html.TextBoxFor(x => x.Duration, new { @class = "form-control", placeholder = "e.g. 4 Hours / 3 Days" })
    </div>

    <div class="mb-2">
        <label>Fare (₹)</label>
        @Html.TextBoxFor(x => x.Fare, new { @class = "form-control", type = "number", step = "0.01" })
    </div>

    <div class="mb-2">
        <label>Display Order</label>
        @Html.TextBoxFor(x => x.DisplayOrder, new { @class = "form-control", type = "number" })
    </div>

    <button type="submit" class="btn btn-success">Save Fare</button>
    <a href="/Admin/DriverFares" class="btn btn-secondary">Cancel</a>
}
