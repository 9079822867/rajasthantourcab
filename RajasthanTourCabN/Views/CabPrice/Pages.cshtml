@model List<RajasthanTourCabN.Models.CabPricing>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<h2>Cab Pricing List</h2>

<a href="/CabPrice/Create" class="btn btn-primary">Add New</a>

<table class="table table-bordered mt-3">
    <tr>
        <th>Vehicle</th>
        <th>City</th>
        <th>4hr</th>
        <th>8hr</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.VehicleName</td>
            <td>@item.City</td>
            <td>₹ @item.Fare4hr</td>
            <td>₹ @item.Fare8hr</td>
            <td>
                <a href="/CabPrice/Edit/@item.Id" class="btn btn-warning btn-sm">Edit</a>

                <a href="/CabPrice/Delete/@item.Id"
                   class="btn btn-danger btn-sm"
                   onclick="return confirm('Delete this record?')">
                    Delete
                </a>
            </td>
        </tr>
    }
</table>