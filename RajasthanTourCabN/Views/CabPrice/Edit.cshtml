@model RajasthanTourCabN.Models.CabPricing
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<h2>Edit Page</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(x => x.Id)
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label>Vehicle Name</label>
        @Html.TextBoxFor(x => x.VehicleName, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>City</label>
        @Html.TextBoxFor(x => x.City, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>4hr Fare</label>
        @Html.TextBoxFor(x => x.Fare4hr, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>8hr Fare</label>
        @Html.TextBoxFor(x => x.Fare8hr, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Extra KM</label>
        @Html.TextBoxFor(x => x.ExtraKm, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Extra Hour</label>
        @Html.TextBoxFor(x => x.ExtraHour, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Display Order</label>
        @Html.TextBoxFor(x => x.DisplayOrder, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-success">Update Page</button>
}
