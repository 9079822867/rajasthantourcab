@model RajasthanTourCabN.Models.Page
@using RajasthanTourCabN.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var fares = ViewBag.Fares as List<DriverFare> ?? new List<DriverFare>();
    var hourly = fares.Where(f => f.Category == "Hourly").ToList();
    var daily = fares.Where(f => f.Category == "Daily").ToList();
}

<style>
    .df-wrap { background:#f5f7fb; padding:42px 0 64px; }
    .df-head { text-align:center; margin-bottom:30px; }
    .df-head h1 { font-weight:700; font-size:1.7rem; color:#111; margin-bottom:8px; }
    .df-head p { color:#5b6b85; margin:0; font-size:.95rem; }
    .df-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; max-width:960px; margin:0 auto; }
    .df-card { background:#fff; border:1px solid #eef1f6; border-radius:14px; overflow:hidden;
               box-shadow:0 6px 20px rgba(20,40,80,.05); }
    .df-card h2 { font-size:1.1rem; font-weight:700; color:#fff; background:#0d6efd; margin:0; padding:14px 18px; }
    .df-table { width:100%; border-collapse:collapse; }
    .df-table td { padding:10px 18px; border-top:1px solid #f0f3f8; font-size:.9rem; color:#41506a; }
    .df-table td.amt { text-align:right; font-weight:700; color:#0d1530; white-space:nowrap; }
    .df-table tr:nth-child(even) td { background:#fafbfd; }
    .df-notes { max-width:960px; margin:34px auto 0; color:#41506a; font-size:.93rem; line-height:1.7; }
    .df-notes h2 { font-weight:700; font-size:1.3rem; color:#111; margin-bottom:14px; }
    .df-notes h3 { font-weight:700; font-size:1.05rem; color:#1b2330; margin:20px 0 10px; }
    .df-notes .fare-breakdown { width:100%; border-collapse:collapse; background:#fff;
                                border:1px solid #eef1f6; border-radius:12px; overflow:hidden; }
    .df-notes .fare-breakdown th { background:#0d1530; color:#fff; text-align:left; padding:12px 16px; font-size:.88rem; }
    .df-notes .fare-breakdown td { padding:11px 16px; border-top:1px solid #f0f3f8; font-size:.88rem; }
    .df-notes ul { padding-left:20px; }
    .df-notes ul li { margin-bottom:6px; }
    .df-cta { text-align:center; margin-top:34px; }
    .df-cta a { display:inline-block; background:#0d6efd; color:#fff; border-radius:10px;
                padding:13px 30px; font-weight:700; text-decoration:none; }
    @@media (max-width:768px) { .df-grid { grid-template-columns:1fr; } }
</style>

<div class="df-wrap">
    <div class="container">
        <div class="df-head">
            <h1>@(Model != null ? Model.Title : "Driver Fares")</h1>
            <p>Transparent hourly and daily charges for hiring a driver</p>
        </div>

        <div class="df-grid">
            <div class="df-card">
                <h2>Hourly Driver Fares</h2>
                <table class="df-table">
                    @foreach (var f in hourly)
                    {
                        <tr><td>@f.Duration</td><td class="amt">&#8377; @f.Fare.ToString("N2")</td></tr>
                    }
                </table>
            </div>
            <div class="df-card">
                <h2>Daily Driver Fares</h2>
                <table class="df-table">
                    @foreach (var f in daily)
                    {
                        <tr><td>@f.Duration</td><td class="amt">&#8377; @f.Fare.ToString("N2")</td></tr>
                    }
                </table>
            </div>
        </div>

        @if (Model != null && !string.IsNullOrWhiteSpace(Model.Content))
        {
            <div class="df-notes">@Html.Raw(HttpUtility.HtmlDecode(Model.Content))</div>
        }

        <div class="df-cta">
            <a href="/hire-driver-in-india"><i class="bi bi-person-badge"></i> Hire a Driver Now</a>
        </div>
    </div>
</div>
