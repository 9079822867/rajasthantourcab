@using RajasthanTourCabN.Code.LIBS
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Rajasthan Tour Cabs – Best Taxi Services in Jaipur & Rajasthan</title>
    <meta name="description" content="@(ViewBag.MetaDescription ?? "")" />
    <meta name="keywords" content="@(ViewBag.MetaKeywords ?? "")" />
    @*@Styles.Render("~/Content/css")
        @Scripts.Render("~/bundles/modernizr")*@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    @*<link href="~/Content/Theme/styles.css" rel="stylesheet" />
        <link href="~/Content/Theme/responsive.css" rel="stylesheet" />
        <link href="~/Content/Theme/style1.css" rel="stylesheet" />*@
    <link href="~/Content/cabs.css" rel="stylesheet" />
</head>
<body>

    <!-- TOP BAR -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="left d-flex align-items-center gap-3 flex-wrap">
                <span class="phone-item">
                    <i class="bi bi-telephone-fill me-1" style="color:var(--gold-lt)"></i>
                    <a href="@("tel:+91"+SiteKey.PhoneNo)">+91 @SiteKey.PhoneNo</a>
                </span>
                <span class="d-none d-md-inline">
                    <i class="bi bi-envelope-fill me-1" style="color:var(--gold-lt)"></i>
                    <a href="mailto:@SiteKey.EmailID">@SiteKey.EmailID</a>
                </span>
                <span class="d-none d-md-inline"><i class="bi bi-lightbulb-fill me-1" style="color:var(--gold-lt)"></i>Guiding You To The Right Answers</span>
            </div>
            <div class="right">
                <a href="/about-us">About Us</a>
                <a href="/gallery">Gallery</a>
                <a href="/contact-us">Contact Us</a>
                <a href="/blog">Blog</a>
            </div>
        </div>
    </div>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-xl site-nav">
        <div class="container">
            <div class="d-flex align-items-center gap-2">
                <div class="logo">
                    <a id="logo" href="/" title="Rajasthan Tour Cabs" data-height="80" data-padding="8">
                        <img class="logo-main scale-with-grid " src="~/Img/logo.png" data-retina="" data-height="534" alt="rajasthan-Tour-cabs-logo" data-no-retina="" style="width: 90px;">
                    </a>
                </div>
            </div>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                @Html.Action("Menu", "Home")
            </div>
        </div>
    </nav>

    @RenderBody()
    <!--FOOTER -->
    @Html.Action("FooterPartial", "Home")


    <!-- Floating WhatsApp -->
    <a href="@("https://api.whatsapp.com/send/?phone=91"+SiteKey.PhoneNo)" class="float-wa" title="Chat on WhatsApp">
        <i class="bi bi-whatsapp"></i>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ── SLIDER ──
        let cur = 0;
        const slides = document.querySelectorAll('.slide');
        const dots = document.querySelectorAll('.dot');

        function updateSlider() {
            slides.forEach((s, i) => s.classList.toggle('active', i === cur));
            dots.forEach((d, i) => d.classList.toggle('active', i === cur));
        }
        function changeSlide(dir) { cur = (cur + dir + slides.length) % slides.length; updateSlider(); }
        function goSlide(i) { cur = i; updateSlider(); }

        let autoTimer = setInterval(() => changeSlide(1), 4800);
        document.querySelectorAll('.slider-btn, .dot').forEach(el =>
            el.addEventListener('click', () => { clearInterval(autoTimer); autoTimer = setInterval(() => changeSlide(1), 4800); })
        );

        // ── SCROLL REVEAL ──
        const ro = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('on'); });
        }, { threshold: 0.08 });
        document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
    </script>
    @Scripts.Render("~/bundles/jquery")
    <script src="@Url.Content("~/Scripts/bootstrap.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
